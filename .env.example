# docker4php
# https://github.com/wodby/docker4php/releases/tag/2.1.9

### Documentation available at https://docs.wodby.com/stacks/php/local
### Changelog can be found at https://github.com/wodby/docker4php/releases
### Images tags format explained at https://github.com/wodby/docker4php#images-tags

### PROJECT SETTINGS

PROJECT_NAME=my-app
COMPOSE_PROJECT_NAME=${PROJECT_NAME}
COMPOSE_ENV=local

X_APP_DOMAIN=${PROJECT_NAME}.docker.localhost
X_APP_URL=https://${X_APP_DOMAIN}
X_APP_URL_PRODUCTION=https://my-app.example.com
X_APP_API_URL_PRODUCTION=https://${X_APP_URL_PRODUCTION}
X_APP_TIMEZONE=Europe/Kyiv

X_TRAEFIK_HOST_WEB=${X_APP_DOMAIN}
X_TRAEFIK_HOST_PMA=pma.${X_APP_DOMAIN}

# pma:password
X_PMA_BASIC_AUTH='pma:$apr1$6l97eyxa$AiWPMdPjxTAFJGOPHU5ID/'

X_DB_HOST=${COMPOSE_PROJECT_NAME}-db-1
X_DB_DATABASE=laravel
X_DB_TEST_DATABASE=laravel_test
X_DB_USERNAME=laravel
X_DB_PASSWORD=laravel
X_DB_ROOT_PASSWORD=password

X_RAY_ENABLED=true
X_RAY_LOCAL_PATH=/path/to/project/src

X_REDIS_HOST=redis

### --- REDIS ----

REDIS_TAG=7.4.3-alpine

